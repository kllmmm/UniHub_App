<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">


    <TextView
        android:id="@+id/bsTargetCourse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Course Name"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="#000000" />


    <TextView
        android:id="@+id/bsPredictedGrade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="7.5"
        android:textAlignment="center"
        android:textSize="64sp"
        android:textStyle="bold"
        android:textColor="#3ec5ff"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Βασίστηκε στους βαθμούς σας:"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="#000000"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/bsContributingCoursesContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/bsBtnClose"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Κλείσιμο"
        android:textColor="#FFFFFF"
        android:backgroundTint="#000000" />

</LinearLayout>